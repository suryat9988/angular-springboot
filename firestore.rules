rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isCoupleMember(coupleId) {
      return isSignedIn()
        && request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.memberUids;
    }

    function isValidPartnerLink(userId) {
      let coupleId = request.resource.data.coupleId;
      return isSignedIn()
        && request.auth.uid != userId
        && request.resource.data.partnerUid == request.auth.uid
        && coupleId is string
        && userId in get(/databases/$(database)/documents/couples/$(coupleId)).data.memberUids
        && request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.memberUids;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isUser(userId);

      match /profile/{docId} {
        allow read: if isSignedIn();
        allow create: if isUser(userId);
        allow update: if isUser(userId) || isValidPartnerLink(userId);
      }

      match /datePlans/{planId} {
        allow read, write: if isUser(userId);
      }

      match /fcmTokens/{tokenId} {
        allow read, write: if isUser(userId);
      }
    }

    match /inviteCodes/{code} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    match /couples/{coupleId} {
      allow read: if isCoupleMember(coupleId);
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.memberUids;
      allow update: if isCoupleMember(coupleId);

      match /messages/{messageId} {
        allow read: if isCoupleMember(coupleId);
        allow create: if isCoupleMember(coupleId)
          && request.resource.data.senderUid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 1000;
      }
    }
  }
}
